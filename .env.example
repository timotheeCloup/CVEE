# ── CVEE Environment Variables ──
# Copy this file to .env and fill in your values.
#
# Security: secrets (FT_CLIENT_ID, FT_CLIENT_SECRET, SB_PASSWORD) are stored in
# GCP Secret Manager (cvee-secrets) for production. This .env is for local dev only.
# Rotate credentials periodically and never commit the real .env file.

# GCP
GCP_PROJECT_ID=
GCS_BUCKET_NAME=

# France Travail API
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# Supabase
SB_HOST=
SB_PORT=
SB_NAME=
SB_USER=
SB_PASSWORD=

# Local dev (PostgreSQL)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# API (local dev)
EMBEDDING_API_URL=
